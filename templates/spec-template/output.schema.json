  "type": "object",
  "additionalProperties": false,
  "required": [
    "label",
    "confidence"
  ],
  "properties": {
    "label": {
      "type": "string"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  }
}
